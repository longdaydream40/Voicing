{
  "ports": {
    "websocket": 9527,
    "udp_broadcast": 9530
  },
  "udp_discovery": {
    "type": "voice_coding_server",
    "required_fields": [
      "type",
      "ip",
      "port",
      "name"
    ],
    "optional_fields": [
      "device_id",
      "os"
    ]
  },
  "messages": {
    "client_to_server": {
      "text": [
        "type",
        "content",
        "auto_enter",
        "send_mode"
      ],
      "ping": [
        "type"
      ]
    },
    "server_to_client": {
      "connected": [
        "type",
        "message",
        "sync_enabled",
        "computer_name",
        "device_id",
        "name",
        "os"
      ],
      "ack": [
        "type",
        "message",
        "clear_input"
      ],
      "pong": [
        "type",
        "sync_enabled"
      ],
      "sync_state": [
        "type",
        "sync_enabled"
      ],
      "sync_disabled": [
        "type",
        "sync_enabled",
        "message"
      ]
    }
  },
  "qr_payload": {
    "required_fields": [
      "v",
      "type",
      "device_id",
      "ip",
      "port",
      "name",
      "os"
    ],
    "optional_fields": [
      "ips"
    ],
    "type": "voicing",
    "version": 1
  }
}
